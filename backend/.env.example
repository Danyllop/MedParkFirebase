# Configuração do Banco de Dados (Neon/PostgreSQL)
DATABASE_URL="postgresql://USUARIO:SENHA@host/neondb?sslmode=require"

# Configuração da API
PORT=3333
NODE_ENV="development"

# Segurança (JWT)
JWT_SECRET="SUA_CHAVE_SUPER_SECRETA_AQUI"
JWT_EXPIRES_IN="24h"

# Segurança (Pepper - NUNCA commite o valor real)
PEPPER_SECRET="SUA_CHAVE_PEPPER_SECRETA_AQUI"

# Senha padrão para novos usuários
DEFAULT_PASSWORD="Mud@1234"
